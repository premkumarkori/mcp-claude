# Copy to `.env` and adjust. Never commit the real .env.

# --- Database (Spring Boot app user) ---------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=appdb
DB_USER=app
DB_PASSWORD=app

# --- MCP read-only role -----------------------------------------------------
# Password assigned to the `mcp_readonly` Postgres role by Flyway migration V2.
# The Analytics MCP (mcp-analytics/) will use this role to connect.
MCP_READONLY_PASSWORD=mcp_readonly_change_me

# --- API --------------------------------------------------------------------
SERVER_PORT=8080
