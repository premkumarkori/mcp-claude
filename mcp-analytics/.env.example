# Copy to `.env` and adjust. Never commit the real .env.

# --- Database (USE THE READ-ONLY ROLE) --------------------------------------
# This DSN MUST point at the `mcp_readonly` Postgres role created by the
# springboot-api Flyway migration V2. Using the app role here defeats the
# entire guardrail model. See PRD §7.
DB_URL=postgresql://mcp_readonly:mcp_readonly_change_me@localhost:5432/appdb

# --- Allowlist --------------------------------------------------------------
# Comma-separated names of views/tables the Analytics MCP may read. Prefer
# PII-masked views (v_*_safe) over raw tables.
TABLE_ALLOWLIST=v_employees_safe,v_orders_safe

# --- Row limits -------------------------------------------------------------
ROW_CAP=1000                # hard cap; no query returns more than this
INLINE_ROW_THRESHOLD=50     # >N rows returns a summary + export_id instead

# --- Query plan check -------------------------------------------------------
MAX_PLAN_COST=100000        # reject queries whose EXPLAIN total cost exceeds this

# --- Paths ------------------------------------------------------------------
AUDIT_LOG_PATH=./audit/queries.jsonl
EXPORT_DIR=./exports

# --- Logging ---------------------------------------------------------------
LOG_LEVEL=INFO
