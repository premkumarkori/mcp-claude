# Copy to `.env` and adjust. Never commit the real .env.

# --- Target Spring Boot API --------------------------------------------------
API_BASE_URL=http://localhost:8080
OPENAPI_PATH=/v3/api-docs
SPEC_CACHE_TTL_SECONDS=60

# --- call_endpoint gating (default: OFF) -------------------------------------
# Must be "true" to enable any live call. See PRD §7.
ALLOW_CALL=false

# Must be "true" AND ALLOW_CALL=true to permit POST/PUT/PATCH/DELETE.
ALLOW_MUTATING_CALLS=false

# Comma-separated list of allowed base URLs. Any call whose URL starts with a
# value not in this list is refused. Keep production out.
CALL_BASE_URL_ALLOWLIST=http://localhost:8080

CALL_TIMEOUT_SECONDS=10

# --- Logging ----------------------------------------------------------------
LOG_LEVEL=INFO
